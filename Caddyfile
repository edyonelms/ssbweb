{
    email admin@ssbeducation.in
}

ssbeducation.in, www.ssbeducation.in {
    encode zstd gzip

    # Long-cache static assets so browsers don't refetch them on every page
    @static {
        path /images/* /build/* /favicon.ico /robots.txt /storage/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    reverse_proxy laravel.test:80 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Real-IP {remote_host}
    }
}
